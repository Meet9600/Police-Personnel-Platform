# Copy to .env and source it, or export these in your shell / systemd unit.
# Main DB role (read/write — used by pipeline and auth)
PGHOST=/var/run/postgresql
PGPORT=5432
PGDATABASE=police_management
PGUSER=app_user
PGPASSWORD=change-me

# Read-only role for the NLP executor (defense in depth)
PG_RO_USER=nlp_readonly
PG_RO_PASSWORD=change-me

# Flask
SECRET_KEY=generate-a-long-random-hex-string
# Demo login fallback (disable in production by leaving users table populated)
DEMO_PASS=admin123
